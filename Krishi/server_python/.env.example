PORT=8000
JWT_SECRET=krishi_secret_key_change_me_in_production
JWT_ALGORITHM=HS256

# Get your free Gemini key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: HuggingFace token for higher ML model quota
HUGGINGFACE_API_KEY=

# ─── Email / OTP Delivery ─────────────────────────────────────────────────────
#
# OPTION A — Resend (RECOMMENDED for cloud/production deployments)
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ 1. Sign up free at https://resend.com (3,000 emails/month free tier)    │
# │ 2. Go to API Keys → Create Key → copy the key below                     │
# │ 3. Set EMAIL_PROVIDER=resend (or leave blank — auto-detected)           │
# │ RESEND_FROM: use 'onboarding@resend.dev' for testing OR your verified   │
# │ domain email (e.g. noreply@yourdomain.com) for production.              │
# └─────────────────────────────────────────────────────────────────────────┘
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM=onboarding@resend.dev

# OPTION B — Gmail SMTP (good for local dev, may be blocked on cloud hosts)
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ 1. Enable 2-Step Verification: https://myaccount.google.com/security    │
# │ 2. Create App Password:        https://myaccount.google.com/apppasswords│
# │ 3. Set EMAIL_PROVIDER=gmail, fill GMAIL_USER and GMAIL_APP_PASSWORD     │
# │ ⚠ Use the 16-char App Password, NOT your regular Gmail password         │
# └─────────────────────────────────────────────────────────────────────────┘
# EMAIL_PROVIDER=gmail
# GMAIL_USER=your_gmail@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# OPTION C — Custom SMTP (Brevo, SendGrid, Mailgun SMTP relay, etc.)
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your_smtp_user
# SMTP_PASSWORD=your_smtp_password
# SMTP_FROM=noreply@yourdomain.com
# SMTP_FROM_NAME=Krishi AI
# SMTP_USE_SSL=False
