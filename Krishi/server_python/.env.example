PORT=8000
JWT_SECRET=krishi_secret_key_change_me_in_production
JWT_ALGORITHM=HS256

# ─── Gemini AI ─────────────────────────────────────────────────────────────────
# Free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: HuggingFace token for higher ML model quota
HUGGINGFACE_API_KEY=

# ─── Supabase PostgreSQL Database ──────────────────────────────────────────────
# Replaces SQLite. Free 500 MB. Data persists across Railway restarts.
#
# HOW TO GET:
#   Supabase → Project Settings → Database
#   → Connection string → URI tab → copy the postgresql:// URI
#
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ─── Supabase Auth JWT Secret ───────────────────────────────────────────────────
# Used by the backend to verify OTP tokens that the frontend gets from Supabase.
#
# HOW TO GET:
#   Supabase → Project Settings → API
#   → JWT Settings → click "Reveal" → copy the secret
#
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# ─── OTP Email (optional — Supabase sends registration emails automatically) ────
# Only needed if you add custom email features beyond OTP registration.
#
# OPTION A — Resend (best for production, 3 000 emails/month free)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# RESEND_FROM=onboarding@resend.dev
#
# OPTION B — Gmail SMTP (good for local dev)
# GMAIL_USER=your_gmail@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── Allowed CORS Origins ──────────────────────────────────────────────────────
# Leave blank to allow all origins (fine for open APIs).
# Set to your GitHub Pages URL to lock it down in production.
# ALLOWED_ORIGINS=https://yourusername.github.io
